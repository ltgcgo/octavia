{
	"name": "@ltgc/octavia",
	"version": "0.0.9",
	"license": "LGPL-3.0-only",
	"imports": {
		"@ltgc/rochelle": "jsr:@ltgcgo/rochelle@^0.2.9",
		"@ltgc/seamstress": "jsr:@ltgcgo/rochelle@^0.1"
	},
	"exports": {
		"./basic": "./dist/basic.d.mts",
		"./bridge": "./dist/bridge.mjs",
		"./cambiare": "./dist/cambiare.mjs",
		"./chord": "./dist/chord.d.mts",
		"./micc": "./dist/micc.d.mts",
		"./state": "./dist/state.d.mts",
		"./disp": "./dist/disp.mjs",
		"./xp_basic": "./dist/xp_basic.d.mts",
		"./xp_state": "./dist/xp_state.d.mts"
	},
	"publish": {
		"include": [
			"dist/README.md",
			"dist/*.mjs",
			"dist/*.mts",
			"libs/**/*.d.mts",
			"README.md"
		]
	},
	"compilerOptions": {
		"lib": [
			"ES5", "ES6",
			"ES2017", "ES2018", "ES2019", "ES2020",
			"ES2021", "ES2022", "ES2023", "ESNext",
			"DOM", "WebWorker"
		],
		"skipLibCheck": true
	},
	"unstable": [
		"broadcast-channel",
		"ffi",
		"net",
		"webgpu"
	],
	"fmt": {
		"useTabs": true,
		"lineWidth": 200,
		"indentWidth": 4,
		"semiColons": true,
		"exclude": [
			"*"
		]
	},
	"lint": {
		"exclude": [
			"*"
		]
	},
	"nodeModulesDir": false,
	"npmRegistry": "http://127.0.0.1:80/"
}
